# ─── PassKit.com (Apple Wallet) ────────────────────────────────────
# From PassKit Dashboard → Developer Tools → API Keys → Create API Key.
# You'll be shown a key + secret pair exactly once. Copy both.
# Auth is JWT HS256 (shared secret), sent as `Authorization: PKAuth <jwt>`.
# Docs: https://help.passkit.com/en/articles/4225662-authenticate-rest-requests-using-jwt
PASSKIT_API_KEY=

# Shared secret (HMAC key). NOT a PEM key.
PASSKIT_API_SECRET=

# Template ID, created manually in PassKit Dashboard → Templates → New Event Ticket
PASSKIT_TEMPLATE_ID=

# PassKit region from Developer Tools → API Region → API Prefix.
# Most accounts are "pub1"; some are "pub2" or others. Check the dashboard.
# Default: pub1
PASSKIT_API_REGION=pub1

# ─── Google Wallet ──────────────────────────────────────────────────
# From Google Cloud Console → IAM & Admin → Service Accounts
# Paste the full service account JSON file contents as a single-line string
GOOGLE_WALLET_SERVICE_ACCOUNT_KEY=

# From Google Wallet Business Console (15+ digit number)
GOOGLE_WALLET_ISSUER_ID=

# Generated once by: pnpm bootstrap:google
# Format: <issuerId>.<classSuffix>
GOOGLE_WALLET_CLASS_ID=

# ─── App ────────────────────────────────────────────────────────────
# Used as the `origins` claim in Google Wallet save JWTs.
# Include scheme, no trailing slash.
NEXT_PUBLIC_APP_ORIGIN=http://localhost:3000
